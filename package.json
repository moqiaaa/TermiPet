{
  "name": "termipet",
  "version": "0.1.0",
  "description": "TermiPet - Desktop coding companion pet",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5174 && electron .\"",
    "build": "vite build && electron-builder --win",
    "build:renderer": "vite build"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "local.termipet",
    "productName": "TermiPet",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "Pets/**/*"
    ],
    "extraResources": [
      {
        "from": "Pets",
        "to": "Pets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon/bar.png"
    }
  }
}
